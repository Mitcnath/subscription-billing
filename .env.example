# Individual credentials used by the db service to initialise Postgres
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# Used by golang-migrate for running migrations
# Note: host must be "db" (the Compose service name) when running inside Docker
# Format: postgres://<user>:<password>@<host>:<port>/<dbname>?sslmode=disable
DB_URL=postgres://your_db_user:your_db_password@db:5432/your_db_name?sslmode=disable

# Used by GORM for database connection
# Note: host must be "db" (the Compose service name) when running inside Docker
# Format: host=<host> user=<user> password=<password> dbname=<dbname> port=<port> sslmode=disable
DSN=host=db user=your_db_user password=your_db_password dbname=your_db_name port=5432 sslmode=disable TimeZone=UTC

# Secret key used to sign and verify JWT tokens
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-this-to-a-long-random-secret-in-production
